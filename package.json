{
  "name": "enotify",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"pnpm dev:worker\" \"pnpm dev:web\"",
    "dev:web": "pnpm --filter web dev",
    "dev:worker": "pnpm --filter worker dev",
    "build": "pnpm --filter web build && pnpm --filter worker build",
    "build:web": "pnpm --filter web build",
    "build:worker": "pnpm --filter worker build",
    "deploy": "pnpm build:web && cd worker && pnpm deploy",
    "typecheck": "pnpm --filter web typecheck && pnpm --filter worker typecheck"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@10.11.0"
}
